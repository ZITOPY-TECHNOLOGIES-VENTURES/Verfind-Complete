generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  tenant
  agent
  admin
}

enum PropertyType {
  Self_contain
  One_bedroom
  Two_bedroom
  Three_bedroom
  Detached_duplex
}

enum PropertyStatus {
  available
  under_offer
  rented
}

enum VerificationStage {
  listing_created
  docs_uploaded
  agent_vetted
  inspection_scheduled
  verified
}

enum TransactionType {
  deposit
  withdrawal
  escrow_hold
  escrow_release
}

enum PaymentStatus {
  pending
  confirmed
  releasing
  released
  failed
  refunded
}

model User {
  id                String   @id @default(uuid())
  username          String
  email             String   @unique
  password          String
  role              Role     @default(tenant)
  isEmailVerified   Boolean  @default(false)
  isKycVerified     Boolean  @default(false)
  phone             String?
  isPhoneVerified   Boolean  @default(false)
  // Agent KYC fields
  businessName      String?
  nin               String?
  driverLicenseUrl  String?
  cacDocUrl         String?
  // Tenant KYC fields
  currentAddress    String?
  ninUrl            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PendingReg {
  id        String   @id @default(uuid())
  username  String
  email     String   @unique
  password  String
  role      Role     @default(tenant)
  phone     String?
  nin       String?
  otp       String
  otpExpiry DateTime
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Property {
  id                  String            @id @default(uuid())
  title               String
  description         String?
  district            String
  address             String?
  type                PropertyType      @default(Self_contain)
  lat                 Float?
  lng                 Float?
  baseRent            Float
  serviceCharge       Float             @default(0)
  cautionFee          Float             @default(0)
  agencyFee           Float?
  legalFee            Float?
  totalInitialPayment Float?
  images              String[]
  videoUrl            String
  bedrooms            Int?
  bathrooms           Int?
  sqm                 Float?
  furnished           Boolean           @default(false)
  parking             Boolean           @default(false)
  listingMode         String            @default("Rent")
  isFeatured          Boolean           @default(false)
  agentId             String
  agentName           String?
  isVerified          Boolean           @default(false)
  verificationStage   VerificationStage @default(listing_created)
  status              PropertyStatus    @default(available)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
}

model Booking {
  id            String   @id @default(uuid())
  propertyId    String
  tenantId      String
  agentId       String
  requestedDate DateTime
  status        String   @default("pending")
  agentNote     String?
  propertyTitle String?
  tenantName    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  propertyId  String?
  type        TransactionType
  amount      Float
  status      String          @default("completed")
  description String?
  reference   String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model Payment {
  id                    String        @id @default(uuid())
  reference             String        @unique
  propertyId            String
  tenantId              String
  agentId               String
  amount                Float
  amountKobo            Float
  description           String?
  status                PaymentStatus @default(pending)
  tenantConfirmedMoveIn Boolean       @default(false)
  moveInConfirmedAt     DateTime?
  inspectionDate        DateTime?
  releaseDate           DateTime?
  paystackData          Json?
  transferReference     String?
  recipientCode         String?
  propertyTitle         String?
  agentName             String?
  tenantEmail           String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

model AgentBank {
  id            String   @id @default(uuid())
  agentId       String   @unique
  bankCode      String
  bankName      String
  accountNumber String
  accountName   String
  recipientCode String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
